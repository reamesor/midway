# public
NEXT_PUBLIC_APP_URL=https://themidway.app
# Solana cluster for wallet adapter: mainnet-beta | devnet | testnet
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta
# Optional custom RPC (Helius, QuickNode, etc.). Falls back to clusterApiUrl(network).
NEXT_PUBLIC_SOLANA_RPC=
NEXT_PUBLIC_MIDWAY_MINT=                 # ecosystem token mint (TOKEN.INFO + wallet deposit/withdraw)
NEXT_PUBLIC_BUY_URL=                     # primary buy CTA (Jupiter/Raydium/pump/etc.)
NEXT_PUBLIC_TWITTER_URL=                 # Twitter/X profile or community
NEXT_PUBLIC_DISCORD_URL=                 # Discord invite
# Midway Spotify — MUSIC tray in-app play (Web Playback SDK + PKCE).
# Create a Spotify Developer app: https://developer.spotify.com/dashboard
# Add Redirect URI: {APP_URL}/spotify/callback  (and http://localhost:3000/spotify/callback for local)
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=
# Optional override; defaults to {origin}/spotify/callback
# NEXT_PUBLIC_SPOTIFY_REDIRECT_URI=https://themidway.app/spotify/callback
# Prefer a playlist/album URL (not a search URL) so in-app play works:
NEXT_PUBLIC_SPOTIFY_URL=https://open.spotify.com/playlist/YOUR_PLAYLIST_ID
NEXT_PUBLIC_TREASURY_PROGRAM_ID=
# Midway play escrow: forced DEMO (10 SOL local pot). LIVE transfers disabled in code.
NEXT_PUBLIC_WALLET_ESCROW=DEMO

# server
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# solana
SOLANA_RPC_URL=
TREASURY_AUTHORITY_KEYPAIR=              # use Squads multisig in prod, never raw key
JUPITER_API_URL=https://quote-api.jup.ag/v6

# fairness
SERVER_SEED_SECRET=

# colors payout mode: LITERAL | STAKE_BASED | PER_COLOR
# LITERAL: each match pays 2× unit bet (1→2×, 2→4×, 3→6×)
NEXT_PUBLIC_PAYOUT_MODE=LITERAL
PAYOUT_MODE=LITERAL
