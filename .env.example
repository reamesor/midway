# public
NEXT_PUBLIC_APP_URL=https://themidway.app
# Solana cluster for wallet adapter: mainnet-beta | devnet | testnet
NEXT_PUBLIC_SOLANA_NETWORK=mainnet-beta
# Optional custom RPC (Helius, QuickNode, etc.). Falls back to clusterApiUrl(network).
NEXT_PUBLIC_SOLANA_RPC=
NEXT_PUBLIC_MIDWAY_MINT=                 # ecosystem token mint (enables MIDWAY deposit/withdraw UI)
NEXT_PUBLIC_TREASURY_PROGRAM_ID=
# Midway play escrow: DEMO = local/session ledger | LIVE = on-chain vault (not wired yet)
NEXT_PUBLIC_WALLET_ESCROW=DEMO

# server
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# solana
SOLANA_RPC_URL=
TREASURY_AUTHORITY_KEYPAIR=              # use Squads multisig in prod, never raw key
JUPITER_API_URL=https://quote-api.jup.ag/v6

# fairness
SERVER_SEED_SECRET=

# colors payout mode: LITERAL | STAKE_BASED | PER_COLOR
# LITERAL matches in-game rules (Bet + Bet×1.04 / ×2 / jackpot ×4.5 on unit bet)
NEXT_PUBLIC_PAYOUT_MODE=LITERAL
PAYOUT_MODE=LITERAL
